#| Info: https://zsh.sourceforge.io/Intro/intro_3.html                         |
#|-----------------------------------------------------------------------------|

# =========================
# Oh My Zsh + Powerlevel10k
# =========================

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

# Uncomment the following line if pasting URLs and other text is messed up.
# DISABLE_MAGIC_FUNCTIONS="true"

# Add wisely, as too many plugins slow down shell startup.
plugins=(git zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ====
# Mise
# ====

# PATH activation of Mise to make packages available to the shell
eval "$(mise activate zsh)"

# ==================
# User Configuration
# ==================

# Claude
alias claude='otter claude-code --permission-mode auto'
alias claude-yolo='otter claude-code --dangerously-skip-permissions'
alias claude-symlink-otter-laptop='ln -s $HOME/.claude/rules $HOME/Library/Application\ Support/Otter/claude-code-user/rules; ln -s $HOME/.claude/skills $HOME/Library/Application\ Support/Otter/claude-code-user/skills'
alias claude-symlink-otter-devbox='ln -s $HOME/.claude/rules $HOME/.config/otter/claude-code-user/rules; ln -s $HOME/.claude/skills $HOME/.config/otter/claude-code-user/skills'

# CMS Development
function cms_devpod_up() {
    cd ~/work/canva
    infra devpod create --name content-management-rpc --target dev --reason "CMS development" --bazel-target //backend/content_management_rpc:image
}
function cms_query_devpod_up() {
    cd ~/work/canva
    infra devpod create --name content-management-query-rpc --target dev --reason "CMS development" --bazel-target //backend/content_management_query_rpc:image
}
function cms_web_up() {
    cd ~/work/canva/web
    USER_LOCALE=en pnpm webpack-dev-server -e admin_cms -p iris-dev
}
alias cms-dev-1="cms_devpod_up"
alias cms-dev-2="cms_query_devpod_up"
alias cms-dev-3="cms_web_up"

